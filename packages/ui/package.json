{
  "name": "@auxarmory/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Elastic-2.0",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "build": "tsc",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.561.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.7.1",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.6",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@auxarmory/typescript-config": "workspace:*",
    "@auxarmory/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./components/*": {
      "default": "./src/components/*"
    },
    "./hooks/*": {
      "default": "./src/hooks/*"
    },
    "./lib/*": {
      "default": "./src/lib/*"
    },
    "./styles.css": "./src/styles/globals.css"
  }
}
